{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":semanticCommits"
  ],
  "schedule": ["before 7am on monday"],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "packageRules": [
    {
      "description": "Group TanStack packages",
      "matchPackageNames": ["/^@tanstack//"],
      "groupName": "tanstack"
    },
    {
      "description": "Group Prisma packages",
      "matchPackageNames": ["/^@prisma//", "/^prisma$/"],
      "groupName": "prisma"
    },
    {
      "description": "Group tRPC packages",
      "matchPackageNames": ["/^@trpc//"],
      "groupName": "trpc"
    },
    {
      "description": "Group Radix UI packages",
      "matchPackageNames": ["/^@radix-ui//"],
      "groupName": "radix-ui"
    },
    {
      "description": "Group Tiptap packages",
      "matchPackageNames": ["/^@tiptap//"],
      "groupName": "tiptap"
    },
    {
      "description": "Group dnd-kit packages",
      "matchPackageNames": ["/^@dnd-kit//"],
      "groupName": "dnd-kit"
    },
    {
      "description": "Group AWS SDK packages",
      "matchPackageNames": ["/^@aws-sdk//"],
      "groupName": "aws-sdk"
    },
    {
      "description": "Group Playwright packages",
      "matchPackageNames": ["/^@playwright//", "/^playwright$/"],
      "groupName": "playwright"
    },
    {
      "description": "Group Testcontainers packages",
      "matchPackageNames": ["/^@testcontainers//", "/^testcontainers$/"],
      "groupName": "testcontainers"
    },
    {
      "description": "Group Better Auth packages",
      "matchPackageNames": ["/^@better-auth//", "/^better-auth$/"],
      "groupName": "better-auth"
    },
    {
      "description": "Group Biome packages",
      "matchPackageNames": ["/^@biomejs//"],
      "groupName": "biome"
    },
    {
      "description": "Group type definitions",
      "matchPackageNames": ["/^@types//"],
      "groupName": "type-definitions"
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor updates for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Do not touch pinned nitro nightly",
      "matchPackageNames": ["nitro"],
      "enabled": false
    }
  ]
}
