# Database
DATABASE_URL=postgresql://puckhub:puckhub_dev@localhost:5432/puckhub

# Auth
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://api.puckhub.localhost

# API
API_PORT=3001
VITE_API_URL=http://api.puckhub.localhost

# Admin
ADMIN_PORT=3000
VITE_WEB_URL=http://web.puckhub.localhost

# Auto-migrate on API startup (set to 'false' to disable)
AUTO_MIGRATE=true

# Uploads
UPLOAD_DIR=../../uploads

# Default admin user (created on first startup if no users exist)
DEFAULT_USER_EMAIL=admin@puckhub.local

# Demo mode (periodic demo reset)
DEMO_MODE=false
DEMO_RESET_CRON=0 */4 * * *

# SMTP (for magic link emails — if not set, emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@puckhub.eu

# Passkey / WebAuthn
PASSKEY_RP_ID=puckhub.localhost
PASSKEY_RP_NAME=PuckHub Admin
PASSKEY_ORIGIN=http://admin.puckhub.localhost

# Domain configuration
BASE_DOMAIN=puckhub.localhost
VITE_BASE_DOMAIN=puckhub.localhost
COOKIE_DOMAIN=puckhub.localhost
SUBDOMAIN_SUFFIX=.puckhub.localhost
TRUSTED_ORIGINS=http://admin.puckhub.localhost,http://platform.puckhub.localhost
BETTER_AUTH_BASE_URL=http://api.puckhub.localhost
CNAME_TARGET=sites.puckhub.localhost

# AI Recaps (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
