{
  "name": "puckhub",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm dev:docker:up && wait-on tcp:5432 && pnpm dev:servers",
    "dev:docker:up": "docker compose -p puckhub -f docker/docker-compose.yml up -d",
    "dev:docker:down": "docker compose -p puckhub -f docker/docker-compose.yml down",
    "dev:services": "turbo dev --log-order=stream",
    "dev:servers": "turbo dev --log-order=stream",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "turbo test",
    "test:api": "pnpm --filter @puckhub/api test",
    "test:e2e": "pnpm --filter @puckhub/admin test",
    "db:generate": "pnpm --filter @puckhub/db db:generate",
    "db:reset": "pnpm --filter @puckhub/db db:reset",
    "capture:screenshots": "node --import tsx scripts/capture-screenshots.ts",
    "docker:build": "node scripts/docker-build.mjs",
    "docker:test": "node scripts/docker-test.mjs",
    "docker:test:keep": "node scripts/docker-test.mjs --keep",
    "docker:test:down": "node scripts/docker-test.mjs --down",
    "docker:push": "node scripts/docker-push.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "sharp",
      "@prisma/client",
      "prisma"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "concurrently": "^9.2.1",
    "playwright": "^1.52.0",
    "turbo": "^2.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
