{
  "name": "@puckhub/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./services": "./src/services/index.ts",
    "./seed": "./src/seed/index.ts",
    "./seed/demoSeed": "./src/seed/demoSeed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "echo '⚠️  db push is disabled — use pnpm db:migrate to create a proper migration' && exit 1",
    "db:seed": "tsx src/seed/run.ts",
    "db:reset": "tsx src/seed/reset.ts",
    "db:studio": "prisma studio",
    "db:migrate:eal": "tsx src/eal-migration/run.ts",
    "db:migrate:eal:analyze": "tsx src/eal-migration/run.ts --analyze-only"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.2",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0"
  }
}
