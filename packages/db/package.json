{
  "name": "@puckhub/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./services": "./src/services/index.ts",
    "./seed": "./src/seed/index.ts",
    "./seed/demoSeed": "./src/seed/demoSeed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db push",
    "db:migrate:prod": "prisma migrate deploy",
    "db:migrate:create": "prisma migrate dev",
    "db:seed": "tsx src/seed/run.ts",
    "db:reset": "tsx src/seed/reset.ts",
    "db:studio": "prisma studio",
    "db:migrate:eal": "tsx src/eal-migration/run.ts",
    "db:migrate:eal:analyze": "tsx src/eal-migration/run.ts --analyze-only"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "better-auth": "^1.4.18",
    "dotenv": "^16.5.0",
    "mysql2": "^3.18.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.1",
    "pg": "^8.16.0",
    "prisma": "^7.4.1"
  }
}
