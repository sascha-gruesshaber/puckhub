{
  "name": "@puckhub/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/trpc/client.ts"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@better-auth/passkey": "^1.6.2",
    "@hono/node-server": "^1.19.14",
    "@hono/trpc-server": "^0.4.2",
    "@prisma/client": "^7.7.0",
    "@puckhub/db": "workspace:*",
    "@trpc/server": "^11.16.0",
    "better-auth": "^1.6.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.12",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "superjson": "^2.2.6",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.11",
    "postgres": "^3.4.9",
    "testcontainers": "^11.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
