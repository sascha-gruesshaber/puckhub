{
  on_demand_tls {
    ask http://api:3000/api/domain-check
  }
}

# Bare domain + www → static placeholder page
{$BASE_DOMAIN}, www.{$BASE_DOMAIN} {
  root * /srv/www
  file_server
  try_files {path} /index.html
}

# API
api.{$BASE_DOMAIN} {
  reverse_proxy api:3000
}

# Admin (proxy /api/uploads to API so image URLs work cross-subdomain)
admin.{$BASE_DOMAIN} {
  @uploads path /api/uploads/*
  reverse_proxy @uploads api:3000
  reverse_proxy admin:3000
}

# Platform
platform.{$BASE_DOMAIN} {
  reverse_proxy platform:3000
}

# Wildcard catch-all → league-site
*.{$BASE_DOMAIN} {
  tls {
    on_demand
  }
  @uploads path /api/uploads/*
  reverse_proxy @uploads api:3000
  reverse_proxy league-site:3000
}
